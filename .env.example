# ============================================================
# Video Dubbing System - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ---- External API Keys ----

# HuggingFace Token (required for first-time pyannote model download)
# Get it at: https://huggingface.co/settings/tokens
# Then accept model terms at:
#   https://huggingface.co/pyannote/speaker-diarization-3.1
#   https://huggingface.co/pyannote/segmentation-3.0
HF_TOKEN=hf_your_token_here

# ---- Translation (OpenAI-compatible API) ----
# Supports OpenAI, OpenRouter, Ollama, vLLM, or any OpenAI-compatible endpoint.
# If not configured, falls back to free local Helsinki-NLP model.

# Model name — examples:
#   OpenAI:      gpt-5
#   OpenRouter:  deepseek/deepseek-v3-5:free  or  deepseek/deepseek-chat-v3-5
#   Ollama:      llama3
TRANSLATION_MODEL=gpt-5

# Base URL — leave empty to use OpenAI default (api.openai.com)
# OpenRouter:  https://openrouter.ai/api/v1
# Ollama:      http://localhost:11434/v1
TRANSLATION_BASE_URL=

# API Key for the translation service
# OpenAI:      your OpenAI key (or set OPENAI_API_KEY below)
# OpenRouter:  your OpenRouter key from https://openrouter.ai/keys
# Ollama:      any non-empty string (e.g. "ollama")
TRANSLATION_API_KEY=

# Legacy OpenAI key — used as fallback if TRANSLATION_API_KEY is not set
OPENAI_API_KEY=

# ---- Device Configuration ----
# Mac Apple Silicon: use cpu for Whisper, mps for diarization
# Windows NVIDIA GPU: use cuda for both

# Whisper backend: faster-whisper (CPU/CUDA) | mlx-whisper (Apple Silicon only)
WHISPER_BACKEND=faster-whisper
# faster-whisper settings (used when WHISPER_BACKEND=faster-whisper)
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
# mlx-whisper model (used when WHISPER_BACKEND=mlx-whisper)
WHISPER_MLX_MODEL=mlx-community/whisper-large-v3-mlx

# Speaker diarization device: cpu | cuda | mps
DIARIZATION_DEVICE=cpu

# ---- Storage Paths ----
# Default uses /tmp - change to a persistent location in production
# DATA_DIR=/data/video-dubbing
# LOCAL_STORAGE_PATH=/data/video-dubbing/storage
# TEMP_DIR=/data/video-dubbing/tmp

# ---- Redis ----
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ---- Models ----
WHISPER_MODEL=large-v3
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1
